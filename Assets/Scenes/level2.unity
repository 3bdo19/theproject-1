  characterCloseUp: {fileID: -6045110389800113485, guid: 5f1d748b164bfdc47b9446a618cfca70, type: 3}
  germanLines:
  - Auf Wiedersehen!
  - "Tsch\xFCs"
  - "Wie geht\u2019s?"
  - Gut, danke.
  - Auf Wiedersehen!
  - Nicht so gut.
  - Und dir?
  - Es geht gut, danke!
  - Magst du Tennis?
  - Ja, ich mag Tennis.
  - "Nein, ich mag Fu\xDFball."
  - K-I-N-O
  - Wie bitte?
  - "Noch einmal bitte!\t"
  arabicLines:
  - Goodbye - formal
  - Bye - informal
  - How are you?
  - Good, thanks.
  - Goodbye - formal
  - Not so good.
  - And you?
  - I'm doing well, thanks!
  - Do you like tennis?
  - Yes, I like tennis.
  - No, I like football.
  - Spelling the word "Cinema"
  - What was that?
  - Once more, please!
  voiceCharacterName: HerrSchmidt
  useCatVoiceInstead: 0
  typingSpeed: 0.05
