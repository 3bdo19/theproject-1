  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Deutsch ist nicht schwer\u2026\r\nUnd auch nicht unm\xF6glich, wenn du
    ein bisschen nachdenkst.\r\nVielleicht\u2026\r\nEs war unm\xF6glich, bevor wir
    dieses Spiel gemacht haben.\r\nDeutsch braucht nur ein System.\r\nUnd dieses
    Spiel ist daf\xFCr gemacht, dich Schritt f\xFCr Schritt zu begleiten.\r\nVokabeln,
    Grammatik und clevere \xDCbungen, die dein Niveau messen.\r\nBist du bereit zu
    spielen?\r\nDann starte das Spiel!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
