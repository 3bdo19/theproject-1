      m_Calls: []
  m_text: "German isn\u2019t hard\u2026\r\nAnd it\u2019s not impossible either, if
    you take a moment to think.\r\nMaybe\u2026\r\nIt used to be impossible before
    we made this game.\r\nGerman just needs a system.\r\nAnd this game is made to
    guide you step by step.\r\nVocabulary, grammar, and smart exercises that measure
    your level.\r\nReady to play?\r\nLet\u2019s start the game!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
